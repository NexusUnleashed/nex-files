{
  "name": "nexfiles",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "refresh:siblings": "node ./scripts/refresh-siblings.mjs",
    "refresh:siblings:fetch": "node ./scripts/refresh-siblings.mjs --fetch-only",
    "refresh:rebuild": "node ./scripts/refresh-siblings.mjs --rebuild",
    "prestart": "node ./scripts/generate-classleads.mjs && node ./scripts/generate-bazaar-json.mjs",
    "start": "docusaurus start",
    "prebuild": "node ./scripts/generate-classleads.mjs && node ./scripts/generate-bazaar-json.mjs",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "gen-classleads": "node ./scripts/generate-classleads.mjs",
    "gen-bazaar": "node ./scripts/generate-bazaar-json.mjs"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/plugin-client-redirects": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@docusaurus/theme-mermaid": "3.10.1",
    "@fontsource/cormorant-garamond": "5.2.11",
    "@fontsource/source-sans-3": "5.2.9",
    "@mdx-js/react": "3.1.1",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "5.6.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "sharp": "0.35.2"
  },
  "overrides": {
    "serialize-javascript": "7.0.6"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=22.0"
  }
}
